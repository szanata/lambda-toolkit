{
  "name": "lambda-toolkit",
  "version": "2.1.0",
  "description": "A set of tools to help and simplify Node Js code development for AWS Lambdas",
  "keywords": [
    "AWS",
    "Athena",
    "CloudWatch",
    "DynamoDB",
    "Lambda",
    "S3",
    "SES",
    "SNS",
    "SQS",
    "SSM",
    "Timestream",
    "API Gateway"
  ],
  "files": [
    "./license",
    "./dist"
  ],
  "type": "module",
  "types": "./dist/index.d.ts",
  "exports": {
    "types": "./dist/index.d.ts",
    "require": "./dist/index.cjs",
    "import": "./dist/index.mjs"
  },
  "author": {
    "name": "Stéfano Zanata",
    "url": "https://szanata.com"
  },
  "contributors": [
    {
      "name": "Lorenzo Zanatta"
    }
  ],
  "scripts": {
    "build": "webpack --stats errors-only",
    "test": "node --experimental-test-module-mocks --test",
    "lint:fix": "eslint --fix",
    "lint": "eslint"
  },
  "license": "GNUv3",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/szanata/lambda-toolkit.git"
  },
  "bugs": {
    "url": "https://github.com/szanata/lambda-toolkit/issues"
  },
  "homepage": "https://github.com/szanata/lambda-toolkit",
  "dependencies": {
    "@aws-sdk/client-athena": "3.1018.0",
    "@aws-sdk/client-cloudwatch-logs": "3.1018.0",
    "@aws-sdk/client-dynamodb": "3.1018.0",
    "@aws-sdk/client-lambda": "3.1018.0",
    "@aws-sdk/client-s3": "3.1018.0",
    "@aws-sdk/client-sesv2": "3.1018.0",
    "@aws-sdk/client-sns": "3.1018.0",
    "@aws-sdk/client-sqs": "3.1018.0",
    "@aws-sdk/client-ssm": "3.1018.0",
    "@aws-sdk/client-timestream-query": "3.1018.0",
    "@aws-sdk/client-timestream-write": "3.1018.0",
    "@aws-sdk/lib-dynamodb": "3.1018.0",
    "@aws-sdk/s3-request-presigner": "3.1018.0"
  },
  "devDependencies": {
    "@eslint/js": "10.0.1",
    "@stylistic/eslint-plugin": "5.10.0",
    "eslint": "10.1.0",
    "eslint-plugin-import": "2.32.0",
    "globals": "17.4.0",
    "webpack": "5.105.4",
    "webpack-cli": "7.0.2"
  },
  "packageManager": "pnpm@10.30.2",
  "pnpm": {
    "overrides": {
      "brace-expansion@<5.0.5": ">=5.0.5"
    }
  }
}
